# Prune unused MathJax package trees and transitive dependencies.
# This follows the same strategy used by LaTeX-Workshop:
# keep the MathJax JS TeX+SVG runtime that the worker imports,
# exclude other shipped builds/sources that VS Code packaging would
# otherwise include.
node_modules/mathjax-full/components/**
node_modules/mathjax-full/es5/**
node_modules/mathjax-full/ts/**
node_modules/mathjax-full/js/output/chtml/**
node_modules/mathjax-full/js/input/asciimath/**
node_modules/mathjax-full/js/input/mathml/**
node_modules/speech-rule-engine/**
node_modules/wicked-good-xpath/**
node_modules/@xmldom/xmldom/**
node_modules/mj-context-menu/**
node_modules/esm/**
